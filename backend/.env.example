################################################################################
# Sarvagya - Assistive Reading Platform
# Environment Configuration Template
#
# IMPORTANT: NEVER COMMIT .env with real API keys!
# Use this file as a template: copy to .env and fill with your actual secrets
################################################################################

# ── APPLICATION ──────────────────────────────────────────────────────────────
APP_NAME=Sarvagya
APP_ENV=development
DEBUG=true

# ── SARVAM AI (https://sarvam.ai) ─────────────────────────────────────────────
# Required for OCR Vision, NMT Translation, Text-to-Speech (Bulbul)
# Get key from: https://console.sarvam.ai/docs/guide
SARVAM_API_KEY=sk_your_sarvam_api_key_here
SARVAM_BASE_URL=https://api.sarvam.ai

# ── GOOGLE VISION API (backup OCR provider) ──────────────────────────────────
# Setup: https://cloud.google.com/docs/authentication/getting-started
# Save service account JSON to: credentials/google_service_account.json
GOOGLE_APPLICATION_CREDENTIALS=./credentials/google_service_account.json
GOOGLE_VISION_API_KEY=your_google_vision_key_here

# ── GOOGLE GEMINI API (backup OCR provider) ──────────────────────────────────
# Get key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── MICROSOFT AZURE OCR (backup provider) ────────────────────────────────────
# Get credentials from Azure Portal > Cognitive Services > Computer Vision
AZURE_OCR_KEY=your_azure_key_here
AZURE_OCR_ENDPOINT=https://your_region.cognitiveservices.azure.com/

# ── FILE UPLOAD ───────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=10
ALLOWED_EXTENSIONS=jpg,jpeg,png,pdf,tiff
UPLOAD_DIR=./uploads

# ── CORS (Cross-Origin Resource Sharing) ─────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173

# ── DATABASE (for future phases) ──────────────────────────────────────────────
# DATABASE_URL=postgresql://user:password@localhost:5432/sarvagya
